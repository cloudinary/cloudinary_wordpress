 /**
  * Only use comment blocks which has a @hook tag and simulate as @class.
+ *
+ * Patched (cloudinary_wordpress): accept standard PHPDoc tag syntax inside
+ * @hook blocks and normalize it to the JSDoc syntax that JSDoc's parser
+ * expects, so source files can keep valid PHPDoc (PHPStan-clean):
+ *   @param  Type $name Desc    ->  @param  {Type} $name Desc   (standard PHPDoc)
+ *   @param  $name {Type} Desc  ->  @param  {Type} $name Desc   (legacy hookdoc)
+ *   @return Type Desc          ->  @return {Type} Desc
+ * Tags already using the {Type} form are left untouched.
  */
 
 'use strict';
 
+// Matches a PHPDoc type expression (unions, generics, arrays, FQCN, etc.).
+var TYPE = '[\\w\\\\|\\[\\]<>,\\s\\.\\$\']+';
+
+// Convert a PHPDoc type to one JSDoc's type-expression parser accepts:
+// drop the leading namespace backslash and turn separators into dots, so
+// PHPDoc FQCNs like \WP_Post or \Cloudinary\Sync become WP_Post / Cloudinary.Sync.
+function jsdocType(type) {
+    return type
+        .trim()
+        .replace(/\\+/g, '\\')   // collapse accidental doubles
+        .split('|')
+        .map(function (part) {
+            return part.trim().replace(/^\\/, '').replace(/\\/g, '.');
+        })
+        .join('|');
+}
+
+function normalizeHookDocblock(comment) {
+    return comment
+        // @param Type $name desc  (standard PHPDoc: type first, not yet braced)
+        .replace(
+            new RegExp('(@param\\s+)(?!\\{)(' + TYPE + '?)\\s+(\\$\\w+)', 'g'),
+            function (m, tag, type, name) {
+                return tag + '{' + jsdocType(type) + '} ' + name;
+            }
+        )
+        // @param $name {Type} desc  (legacy hookdoc: name first, braced type after)
+        .replace(
+            /(@param\s+)(\$\w+)\s+\{([^}]+)\}/g,
+            function (m, tag, name, type) {
+                return tag + '{' + jsdocType(type) + '} ' + name;
+            }
+        )
+        // @return/@returns Type desc  (standard PHPDoc: not yet braced)
+        .replace(
+            new RegExp('(@returns?\\s+)(?!\\{)(' + TYPE + '?)(\\s|\\*/|$)', 'g'),
+            function (m, tag, type, tail) {
+                if (!type.trim()) { return m; }
+                return tag + '{' + jsdocType(type) + '}' + tail;
+            }
+        );
+}
+
 exports.handlers = {
     beforeParse: function(e) {
         // a JSDoc comment looks like: /**[one or more chars]*/
